<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Tıklanınca veya seçilince -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FBDCAD"
                android:endColor="#DBFFB1"
                android:angle="45" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#90FFFFFF" />
        </shape>
    </item>

    <!-- Normal görünüm -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FBDCAD"
                android:endColor="#EDD5B2"
                android:angle="45" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#95887F" />
            <padding
                android:left="12dp"
                android:top="12dp"
                android:right="12dp"
                android:bottom="12dp" />
        </shape>
    </item>
</selector>
